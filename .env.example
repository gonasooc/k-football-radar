# Local `.env` template. Copy to `.env` and fill in what you need.
# Production values live elsewhere: web build args in deploy/macos/production.env,
# and CI collection secrets in the repo's GitHub Actions secrets.

# ── Web app (local `pnpm dev`/`build`) ──
# In production these are injected at build time from deploy/macos/production.env.
NEXT_PUBLIC_SITE_URL=
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX. Leave empty to disable.
NEXT_PUBLIC_GA_ID=

# ── Local collectors ──
# Only needed to run collection locally (pnpm run collect:local /
# collect:youtube:local / backfill:youtube-tags:local). In CI these come from
# GitHub Actions secrets, so leave them empty if you never collect locally.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
YOUTUBE_API_KEY=

# ── Collection tuning (optional; empty falls back to the in-code defaults) ──
YOUTUBE_MAX_PAGES_PER_QUERY=2
YOUTUBE_BACKFILL_DAYS=90
MAX_RETAINED_YOUTUBE_ITEMS=500
